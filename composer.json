{
    "name": "peppermint/impersonate",
    "description": "Admin impersonation for Peppermint Laravel apps — a thin wrapper around lab404/laravel-impersonate with Spatie role gating and Inertia banner support.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "impersonate",
        "spatie",
        "inertia",
        "peppermint"
    ],
    "authors": [
        {
            "name": "Peppermint Digital"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "lab404/laravel-impersonate": "^1.7.8"
    },
    "autoload": {
        "psr-4": {
            "Peppermint\\Impersonate\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Peppermint\\Impersonate\\ImpersonateServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
